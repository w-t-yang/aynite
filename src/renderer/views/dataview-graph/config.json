{
  "name": "Graph",
  "description": "Force-directed graph visualization for network and relationship data",
  "author": "Aynite",
  "version": "1.0.0",
  "expected_file_type": {
    "ext": "json",
    "schema": {
      "type": "object",
      "required": ["nodes", "links"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "group": { "type": "number" }
            }
          }
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target"],
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "value": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "key_bindings": {},
  "i18n": {
    "zh": {
      "name": "关系图",
      "description": "力导向图可视化，适用于网络和关系数据"
    }
  }
}
