{
  "name": "Data Chart",
  "description": "Multi-type chart view supporting bar, line, area, pie, and radar charts",
  "author": "Aynite",
  "version": "1.0.0",
  "expected_file_type": {
    "ext": "json",
    "schema": {
      "type": "object",
      "required": ["keys", "data"],
      "properties": {
        "title": { "type": "string" },
        "keys": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "data": {
          "type": "array",
          "items": { "type": "object" },
          "minItems": 1
        }
      }
    }
  },
  "key_bindings": {}
}
