{
  "name": "Chart",
  "description": "Interactive bar, line, area, pie, and radar charts",
  "author": "Aynite",
  "version": "1.0.0",
  "expected_file_type": {
    "ext": "json",
    "schema": {
      "type": "object",
      "required": ["keys", "data"],
      "properties": {
        "title": { "type": "string" },
        "keys": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "data": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    }
  },
  "key_bindings": {},
  "i18n": {
    "zh": {
      "name": "图表",
      "description": "交互式柱状图、折线图、面积图、饼图和雷达图"
    }
  }
}
