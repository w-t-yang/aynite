{
  "output": ".jscpd-output",
  "threshold": 15,
  "reporters": ["console", "silent"],
  "ignore": [
    "node_modules/**",
    ".git/**",
    "out/**",
    "dist/**",
    "dist-standalone/**",
    "coverage/**",
    "resources/**",
    "tests/**",
    "scripts/**",
    "**/Treeview.tsx"
  ],
  "absolute": true,
  "minLines": 6,
  "minTokens": 30,
  "pattern": "src/**/*.{ts,tsx}",
  "blame": false,
  "gitignore": true
}
