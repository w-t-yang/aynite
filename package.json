{
  "name": "aynite-app",
  "version": "1.0.0-beta.5",
  "main": "./out/main/index.js",
  "author": "Wentao Yang <winterock.yang@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test:ai": "tsx scripts/test-ai-providers.ts",
    "patch-tag": "npm version patch && git push && git push --tags",
    "patch-beta": "npm version prerelease --preid=beta && git push && git push --tags",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:appimage": "electron-vite build && electron-builder --linux AppImage",
    "build:deb": "electron-vite build && electron-builder --linux deb",
    "build:pacman": "electron-vite build && electron-builder --linux pacman",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/deepseek": "^2.0.30",
    "@ai-sdk/google": "^3.0.65",
    "@ai-sdk/openai": "^3.0.54",
    "@google/genai": "^1.29.0",
    "@tiptap/extension-mention": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/prismjs": "^1.26.6",
    "ai": "^6.0.169",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-arborist": "^3.5.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-simple-code-editor": "^0.14.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tippy.js": "^6.3.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.aynite.app",
    "productName": "Aynite",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "w-t-yang",
      "repo": "aynite"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/skills",
        "to": "skills",
        "filter": ["**/*"]
      },
      {
        "from": "resources/commands",
        "to": "commands",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman"
      ],
      "maintainer": "Wentao <winterock.yang@gmail.com>",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
