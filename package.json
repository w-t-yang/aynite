{
  "name": "aynite-app",
  "version": "1.0.0-beta.15",
  "main": "./out/main/index.js",
  "author": "Wentao Yang <winterock.yang@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:views-dev && electron-vite dev",
    "build": "npm run build:views && electron-vite build",
    "preview": "electron-vite preview",
    "test:ai": "tsx scripts/test-ai-providers.ts",
    "dev:views": "vite --config vite.views.config.ts",
    "count:aynite": "tsx scripts/count-aynite-commits.ts",
    "count:fd": "tsx scripts/count-fd.ts",
    "contributors": "tsx scripts/update-contributors.ts",
    "audit:base": "npm run audit:preload && npm run audit:constants && npm run audit:types && npm run audit:window && npm run audit:zindex && npm run audit:path && npm run audit:main-import && npm run audit:event && npm run audit:theme && npm run audit:components",
    "audit:standalone": "npm run audit:bridge && npm run audit:communication && npm run audit:complexity && npm run audit:exports && npm run audit:patterns",
    "audit:tools": "npm run audit:duplication && npm run audit:circular && npm run audit:ast-grep && npm run audit:deadcode",
    "audit:all": "npm run audit:base && npm run audit:standalone && npm run audit:tools",
    "audit:check": "tsx scripts/audit-ipc-bridge.ts --check && npm run audit:base -- --check",
    "audit:preload": "tsx scripts/base-audit-preload.ts",
    "audit:constants": "tsx scripts/base-audit-constants.ts",
    "audit:types": "tsx scripts/base-audit-types.ts",
    "audit:window": "tsx scripts/base-audit-window.ts",
    "audit:zindex": "tsx scripts/base-audit-zindex.ts",
    "audit:path": "tsx scripts/base-audit-path.ts",
    "audit:main-import": "tsx scripts/base-audit-main-import.ts",
    "audit:event": "tsx scripts/base-audit-event.ts",
    "audit:theme": "tsx scripts/base-audit-theme.ts",
    "audit:components": "tsx scripts/base-audit-components.ts",
    "audit:bridge": "tsx scripts/audit-ipc-bridge.ts",
    "audit:bridge-architecture": "tsx scripts/audit-bridge-architecture.ts",
    "audit:communication": "tsx scripts/audit-communication.ts",
    "audit:complexity": "tsx scripts/audit-complexity.ts",
    "audit:exports": "tsx scripts/audit-exports.ts",
    "audit:patterns": "tsx scripts/audit-patterns.ts",
    "audit:duplication": "jscpd --config .jscpd.json",
    "audit:circular": "madge --warning --circular --extensions ts,tsx src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/lib/ tests/main/",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write --unsafe src/ tests/",
    "inventory": "tsx scripts/component-inventory.ts",
    "audit:ast-grep": "ast-grep scan",
    "audit:deadcode": "knip",
    "build:views": "vite build --config vite.views.config.ts",
    "build:views-dev": "VITE_VIEWS_DEV=true vite build --config vite.views.config.ts",
    "serve:views": "npm run build:views && npx serve dist-views",
    "patch-tag": "npm version patch && git push && git push --tags",
    "patch-beta": "npm version prerelease --preid=beta && git push && git push --tags",
    "build:linux": "npm run build:views && electron-vite build && electron-builder --linux",
    "build:appimage": "npm run build:views && electron-vite build && electron-builder --linux AppImage",
    "build:deb": "npm run build:views && electron-vite build && electron-builder --linux deb",
    "build:pacman": "npm run build:views && electron-vite build && electron-builder --linux pacman",
    "build:mac": "npm run build:views && electron-vite build && electron-builder --mac",
    "build:win": "npm run build:views && electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "overrides": {
    "madge": {
      "typescript": "$typescript"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write --unsafe"
    ],
    "tests/**/*.{ts,tsx}": [
      "biome check --write --unsafe"
    ],
    "src/**/*.{json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/openai": "^3.0.65",
    "@excalidraw/excalidraw": "^0.18.1",
    "@google/genai": "^1.52.0",
    "@tiptap/extension-mention": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@types/prismjs": "^1.26.6",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.191",
    "ai-sdk-ollama": "^3.8.4",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "electron-is-dev": "^3.0.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "motion": "^12.40.0",
    "pdfjs-dist": "^5.7.284",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.6",
    "react-arborist": "^3.8.0",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-simple-code-editor": "^0.14.1",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.6.0",
    "tippy.js": "^6.3.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^6.0.0-beta.1",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.4",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "madge": "^8.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.aynite.app",
    "productName": "Aynite",
    "protocols": {
      "name": "Aynite Protocol",
      "schemes": [
        "aynite"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "w-t-yang",
      "repo": "aynite"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-views",
        "to": "dist-views",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/skills",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/commands",
        "to": "commands",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/aynite-playbook",
        "to": "aynite-playbook",
        "filter": [
          "**/*"
        ]
      }
    ],
    "icon": "build/icon.png",
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "maintainer": "Wentao <winterock.yang@gmail.com>",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
